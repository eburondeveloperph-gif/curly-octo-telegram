{
  "name": "translator-security-policy",
  "version": "1.0.0",
  "description": "Security policy for the multilingual translator application",
  "rules": {
    "dependencies": {
      "audit": {
        "frequency": "weekly",
        "severity": ["moderate", "high", "critical"],
        "action": "fix"
      },
      "licenses": {
        "allowed": ["MIT", "Apache-2.0", "BSD-2-Clause", "BSD-3-Clause", "ISC"],
        "forbidden": ["GPL-2.0", "GPL-3.0", "AGPL"]
      }
    },
    "code": {
      "no-secrets": true,
      "no-hardcoded-credentials": true,
      "no-eval": true,
      "no-inner-html": true,
      "content-security-policy": "strict"
    },
    "api": {
      "rate-limiting": true,
      "authentication": true,
      "https-only": true,
      "cors": "restricted"
    },
    "data": {
      "encryption": "aes-256-gcm",
      "hashing": "bcrypt",
      "pii-protection": true,
      "data-retention": "30-days"
    }
  },
  "permissions": {
    "filesystem": {
      "read": ["config", "logs"],
      "write": ["logs", "temp"],
      "forbidden": ["system", "sensitive"]
    },
    "network": {
      "allowed-domains": [
        "api.google.com",
        "supabase.co",
        "localhost"
      ],
      "blocked-domains": [
        "*.malicious.com",
        "*.suspicious.net"
      ]
    },
    "browser": {
      "permissions": [
        "microphone",
        "audio"
      ],
      "forbidden": [
        "camera",
        "geolocation",
        "notifications"
      ]
    }
  },
  "monitoring": {
    "logging": {
      "level": "info",
      "retention": "90-days",
      "pii-filtering": true
    },
    "alerts": {
      "security-events": true,
      "performance-issues": true,
      "error-threshold": "5%"
    }
  }
}
